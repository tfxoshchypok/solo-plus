{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.js", "src/**/*.d.ts", "schema/**/*.js", "tests/**/*.js"],
  "exclude": ["node_modules", "resources"]
}
